{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "ReverseProxy": {
    "Routes": {
      "vehicleRoute": {
        "ClusterId": "vehicleCluster",
        "Match": {
          "Path": "/gateway/vehicles/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/v1/vehicles/{**catch-all}"
          }
        ]
      }
    },
    "Clusters": {
      "vehicleCluster": {
        "Destinations": {
          "vehicleApi": {
            "Address": "http://localhost:5001"
          }
        }
      }
    }
  }
}